---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import EmailSignup from '../components/EmailSignup.astro';
import LeadMagnetCTA from '../components/LeadMagnetCTA.astro';
import { CATEGORY_META } from '../content.config';
import { getArticleUrl } from '../utils/urls';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  keywords,
  category,
  featuredImage,
  schema,
} = post.data;

const cat = CATEGORY_META[category];
const url = getArticleUrl(post);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: cat.label, url: cat.path },
  { name: title, url, current: true },
];

const articleData = {
  title,
  description,
  pubDate,
  updatedDate,
  author,
  keywords,
  image: featuredImage,
  url,
};

const primaryType: 'Article' | 'FAQPage' | 'HowTo' =
  schema === 'faq' ? 'FAQPage' : schema === 'howto' ? 'HowTo' : 'Article';

const readingMinutes = Math.max(1, Math.round(description.length / 5 / 220));
---

<BaseLayout
  title={title}
  description={description}
  image={featuredImage}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate}
  author={author}
  keywords={keywords}
>
  <JsonLd type={primaryType} data={articleData} />
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <article class="mx-auto max-w-2xl px-6 sm:px-8 lg:px-0 py-14 md:py-20">
    <Breadcrumbs items={breadcrumbItems} />

    <header class="mt-6 mb-10">
      <a
        href={cat.path}
        class="eyebrow inline-block text-gold-700 hover:text-gold-600 transition-colors"
      >
        {cat.label}
      </a>
      <h1
        class="mt-4 font-serif leading-[1.05] tracking-[-0.025em]
               text-[2.5rem] sm:text-[3rem] md:text-[3.5rem] text-navy-900"
      >
        {title}
      </h1>
      <p class="mt-5 text-xl text-navy-800/80 leading-relaxed">
        {description}
      </p>

      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
        <span class="font-semibold text-navy-900">By {author}</span>
        <span class="text-navy-300" aria-hidden="true">·</span>
        <time datetime={pubDate.toISOString()} class="text-navy-600">
          {pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        {
          updatedDate && (
            <>
              <span class="text-navy-300" aria-hidden="true">·</span>
              <time datetime={updatedDate.toISOString()} class="text-navy-600">
                Updated{' '}
                {updatedDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
            </>
          )
        }
      </div>
    </header>

    {
      featuredImage && (
        <img
          src={featuredImage}
          alt=""
          class="w-full rounded-lg border border-navy-100 mb-10"
        />
      )
    }

    <div class="prose-article" data-pagefind-body>
      <slot />
    </div>

    <hr class="mt-14 mb-10 border-navy-100" />

    <LeadMagnetCTA />

    <div class="mt-8">
      <EmailSignup />
    </div>

    <p class="mt-8 text-sm text-navy-700">
      <a
        href={cat.path}
        class="font-semibold hover:text-gold-700 transition-colors"
      >
        ← More in {cat.label}
      </a>
    </p>
  </article>

  <Fragment slot="head">
    <meta name="pagefind-ignore" content="false" />
  </Fragment>
</BaseLayout>
