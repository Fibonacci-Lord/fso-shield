---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { CATEGORY_META, type Category } from '../content.config';

interface Props {
  category: Category;
  title?: string;
  description?: string;
}

const { category } = Astro.props;
const meta = CATEGORY_META[category];
const title = Astro.props.title ?? meta.label;
const description = Astro.props.description ?? meta.description;

const allPosts = await getCollection('blog', (entry: CollectionEntry<'blog'>) => {
  return entry.data.category === category && !entry.data.draft;
});

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: meta.label, url: meta.path, current: true },
];
---

<BaseLayout title={title} description={description} keywords={[meta.label]}>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <section class="bg-navy-700 text-white border-b-4 border-gold-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="mt-3 font-serif text-4xl md:text-5xl text-white leading-tight">
        {title}
      </h1>
      <p class="mt-4 text-lg text-navy-100 max-w-2xl">{description}</p>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="prose-article max-w-3xl">
      <slot />
    </div>

    <section class="mt-12">
      <h2 class="font-serif text-2xl md:text-3xl text-navy-800">
        Articles in {meta.label}
      </h2>
      {
        posts.length === 0 ? (
          <p class="mt-3 text-navy-600">
            New articles in this category will appear here as they're
            published.
          </p>
        ) : (
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <ArticleCard post={post} />
            ))}
          </div>
        )
      }
    </section>

    <section class="mt-14">
      <EmailSignup />
    </section>
  </div>
</BaseLayout>
