---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { CATEGORY_META, type Category } from '../content.config';

interface Props {
  category: Category;
  title?: string;
  description?: string;
}

const { category } = Astro.props;
const meta = CATEGORY_META[category];
const title = Astro.props.title ?? meta.label;
const description = Astro.props.description ?? meta.description;

const allPosts = await getCollection(
  'blog',
  (entry: CollectionEntry<'blog'>) =>
    entry.data.category === category && !entry.data.draft
);

const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: meta.label, url: meta.path, current: true },
];
---

<BaseLayout title={title} description={description} keywords={[meta.label]}>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <section
    class="hero-ink relative overflow-hidden border-b-4 border-gold-500"
  >
    <div class="hero-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
    <div
      class="relative max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-24"
    >
      <Breadcrumbs items={breadcrumbItems} tone="light" />
      <ScrollReveal>
        <p class="eyebrow mt-5 text-gold-300">{meta.label}</p>
      </ScrollReveal>
      <ScrollReveal delay={80}>
        <h1
          class="mt-3 font-serif text-white leading-[1.05] tracking-[-0.025em]
                 text-[2.75rem] sm:text-[3.25rem] md:text-[4rem]
                 max-w-[20ch]"
        >
          {title}
        </h1>
      </ScrollReveal>
      <ScrollReveal delay={160}>
        <p
          class="mt-5 text-lg md:text-xl text-navy-100 max-w-2xl leading-relaxed"
        >
          {description}
        </p>
      </ScrollReveal>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-16">
    <div class="prose-article">
      <slot />
    </div>

    <section class="mt-16">
      <ScrollReveal>
        <h2 class="font-serif text-3xl md:text-4xl text-navy-900">
          Articles in {meta.label}.
        </h2>
      </ScrollReveal>
      {
        posts.length === 0 ? (
          <p class="mt-4 text-navy-700">
            New articles in this category will appear here as they're
            published.
          </p>
        ) : (
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {posts.map((post, i) => (
              <ScrollReveal delay={i * 80}>
                <ArticleCard post={post} />
              </ScrollReveal>
            ))}
          </div>
        )
      }
    </section>

    <section class="mt-16">
      <EmailSignup />
    </section>
  </div>
</BaseLayout>
