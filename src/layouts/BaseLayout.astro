---
import '../styles/global.css';

// Self-hosted display + UI + mono typography (no external requests at runtime).
import '@fontsource/instrument-serif/400.css';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/jetbrains-mono/400.css';

import { ClientRouter } from 'astro:transitions';
import SEO from '../components/SEO.astro';
import JsonLd from '../components/JsonLd.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description?: string;
  canonical?: string | URL;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  keywords?: string[];
  noindex?: boolean;
  /** Render the default Organization JSON-LD on this page. Defaults to true on the home page. */
  includeOrganization?: boolean;
}

const {
  title,
  description,
  canonical,
  image,
  type,
  publishedTime,
  modifiedTime,
  author,
  keywords,
  noindex,
  includeOrganization = Astro.url.pathname === '/',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="google-site-verification"
      content="nMPobL0chGcOXB3D_PJQYgQIlvor1j3bvOQCc2sNudk"
    />
    <meta
      name="google-site-verification"
      content="nLWeJGsYZ7UPB8fD1pleG8m39MO0cpOdUrS27u2M01c"
    />
    <meta
      name="msvalidate.01"
      content="77BD3DEFAFACA6EB38C1477D21CBF576"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} RSS feed`}
      href="/rss.xml"
    />
    <link
      rel="sitemap"
      type="application/xml"
      href="/sitemap-index.xml"
    />
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      image={image}
      type={type}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      keywords={keywords}
      noindex={noindex}
    />
    {
      includeOrganization && (
        <JsonLd type="Organization" data={{}} />
      )
    }
    <!-- Astro View Transitions — crossfade between pages, respects prefers-reduced-motion. -->
    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-navy-50 text-navy-900">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-gold-500 focus:text-navy-900 focus:px-3 focus:py-1 focus:rounded"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1 w-full">
      <slot />
    </main>
    <Footer />

    <!-- Cloudflare Web Analytics -->
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "9bcc525f1c0745eda3fb5a133d375589"}'
      is:inline></script>

    <!--
      Kit newsletter form handler + ScrollReveal observer.
      Both rebind on astro:page-load so they survive View Transitions.
    -->
    <script is:inline>
      function enhanceKitForms() {
        document
          .querySelectorAll('form[data-kit-form]:not([data-enhanced])')
          .forEach((form) => {
            form.setAttribute('data-enhanced', 'true');
            form.addEventListener('submit', async (event) => {
              event.preventDefault();
              const btn = form.querySelector('button[type="submit"]');
              const originalText = btn ? btn.textContent : '';
              if (btn) {
                btn.disabled = true;
                btn.textContent = 'Submitting…';
              }
              try {
                await fetch(form.action, {
                  method: 'POST',
                  mode: 'no-cors',
                  body: new FormData(form),
                });
                const success = form.parentElement?.querySelector(
                  '[data-kit-success]'
                );
                form.hidden = true;
                if (success) success.hidden = false;
              } catch (err) {
                if (btn) {
                  btn.disabled = false;
                  btn.textContent = originalText;
                }
                const error = form.parentElement?.querySelector(
                  '[data-kit-error]'
                );
                if (error) error.hidden = false;
              }
            });
          });
      }

      function enhanceScrollReveals() {
        const els = document.querySelectorAll(
          '.scroll-reveal:not([data-reveal-observed])'
        );
        if (!els.length) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => {
          el.setAttribute('data-reveal-observed', 'true');
          observer.observe(el);
        });
      }

      function onReady() {
        enhanceKitForms();
        enhanceScrollReveals();
      }

      document.addEventListener('astro:page-load', onReady);
    </script>
  </body>
</html>
