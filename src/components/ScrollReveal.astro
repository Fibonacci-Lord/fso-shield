---
/**
 * ScrollReveal — fades and rises 20px on intersection.
 *
 * The IntersectionObserver lives in BaseLayout's astro:page-load handler so
 * it survives View Transitions. This component is purely declarative.
 *
 * Usage:
 *   <ScrollReveal>…</ScrollReveal>
 *   <ScrollReveal delay={100} tag="section">…</ScrollReveal>
 *   <ScrollReveal class="my-extra-class">…</ScrollReveal>
 */

interface Props {
  /** Delay before the reveal animation starts, in ms. Useful for staggering grids. */
  delay?: number;
  /** Wrapper element. Defaults to <div>. */
  tag?: keyof HTMLElementTagNameMap;
  class?: string;
}

const { delay = 0, tag = 'div', class: className = '' } = Astro.props;
const Tag = tag as any;

const style = delay > 0 ? `--reveal-delay: ${delay}ms` : undefined;
---

<Tag class:list={['scroll-reveal', className]} style={style}>
  <slot />
</Tag>
