---
/**
 * LeadMagnetCTA — editorial callout card for the free NISPOM Quick-Check.
 *
 * Used in article pages and anywhere a contextual CTA fits. Not a popup,
 * not aggressive — sized to read like an author's side-note.
 */

interface Props {
  /** Tighten spacing for inline placement inside long-form articles. */
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<aside
  class:list={[
    'relative rounded-lg border border-navy-200 bg-navy-100/60',
    'border-l-4 border-l-gold-500',
    compact ? 'p-5' : 'p-6 md:p-7',
  ]}
  aria-label="Free resource"
>
  <div class="flex items-start gap-4">
    <div
      class="shrink-0 mt-0.5 flex h-10 w-10 items-center justify-center rounded-md bg-navy-900 text-gold-400"
      aria-hidden="true"
    >
      <svg
        class="h-5 w-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.75"
      >
        <rect x="4" y="3" width="16" height="18" rx="2" />
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="m7.5 8.5 1.5 1.5 3-3M7.5 13.5l1.5 1.5 3-3M14.5 8h3M14.5 13h3M14.5 18h3"
        />
      </svg>
    </div>

    <div class="flex-1 min-w-0">
      <p class="eyebrow text-gold-700">Free resource</p>
      <p
        class="mt-1.5 font-serif text-[1.3rem] md:text-[1.4rem] text-navy-900 leading-snug"
      >
        The 15 NISPOM items DCSA cites most.
      </p>
      <p class="mt-1 text-[0.95rem] text-navy-800/80 leading-relaxed">
        Download the free Quick-Check. Run it before your next assessment and
        stop guessing what DCSA will look for.
      </p>
      <a
        href="/free-checklist"
        class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-navy-800 hover:text-gold-700 transition-colors"
      >
        Get the free checklist
        <span
          class="transition-transform group-hover:translate-x-0.5"
          aria-hidden="true">→</span
        >
      </a>
    </div>
  </div>
</aside>
