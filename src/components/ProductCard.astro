---
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const { title, description, price, category, buyUrl, featured, image } =
  product.data;

const priceDisplay =
  typeof price === 'number'
    ? `$${price.toFixed(price % 1 === 0 ? 0 : 2)}`
    : price;

// Icon selection by category keyword.
type IconKey = 'checklist' | 'slides' | 'document';

function iconForCategory(cat: string): IconKey {
  const c = cat.toLowerCase();
  if (c.includes('checklist')) return 'checklist';
  if (c.includes('slide') || c.includes('briefing')) return 'slides';
  return 'document';
}

const iconKey = iconForCategory(category);
---

<article
  class:list={[
    'card group flex flex-col h-full overflow-hidden rounded-lg',
    featured ? 'card-featured' : '',
  ]}
>
  {
    image ? (
      <a
        href={buyUrl}
        rel="noopener"
        target="_blank"
        class="block overflow-hidden"
      >
        <img
          src={image}
          alt=""
          loading="lazy"
          class="w-full h-32 object-cover"
        />
      </a>
    ) : (
      <a
        href={buyUrl}
        rel="noopener"
        target="_blank"
        class="relative block h-24 bg-navy-900 hero-grid"
        aria-hidden="true"
        tabindex="-1"
      >
        <div class="absolute inset-0 flex items-center justify-center">
          {iconKey === 'checklist' && (
            <svg
              class="h-10 w-10 text-gold-500"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <rect x="4" y="3" width="16" height="18" rx="2" />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m7.5 8.5 1.5 1.5 3-3M7.5 13.5l1.5 1.5 3-3M14.5 8h3M14.5 13h3M14.5 18h3"
              />
            </svg>
          )}
          {iconKey === 'slides' && (
            <svg
              class="h-10 w-10 text-gold-500"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <rect x="3" y="4" width="18" height="13" rx="1.5" />
              <path stroke-linecap="round" d="M3 14l4-3 3 2 4-4 7 5M8 20h8M12 17v3" />
            </svg>
          )}
          {iconKey === 'document' && (
            <svg
              class="h-10 w-10 text-gold-500"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8l-5-5z"
              />
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 3v5h5" />
              <path stroke-linecap="round" d="M8.5 13h7M8.5 16.5h5" />
            </svg>
          )}
        </div>
      </a>
    )
  }

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center justify-between gap-2">
      <span class="eyebrow text-gold-700">{category}</span>
      {
        featured && (
          <span class="inline-block rounded-full bg-gold-100 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wider text-gold-800">
            Featured
          </span>
        )
      }
    </div>

    <h3 class="mt-3 font-serif text-xl text-navy-900 leading-snug">
      <a
        href={buyUrl}
        rel="noopener"
        target="_blank"
        class="hover:text-gold-700 transition-colors"
      >
        {title}
      </a>
    </h3>

    <p class="mt-2 text-[0.95rem] text-navy-800/80 leading-relaxed flex-1">
      {description}
    </p>

    <div class="mt-5 flex items-center justify-between">
      <span class="font-semibold text-navy-900 text-lg">{priceDisplay}</span>
      <a
        href={buyUrl}
        rel="noopener"
        target="_blank"
        class="inline-flex items-center gap-1 rounded-md bg-navy-900 text-white px-4 py-2 text-sm font-semibold hover:bg-navy-950 transition-colors"
      >
        View product
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</article>
