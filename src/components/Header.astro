---
import { SITE, NAV_LINKS } from '../consts';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header
  class="sticky top-0 z-40 w-full bg-navy-900/95 text-white backdrop-blur-md shadow-md border-b-2 border-gold-500"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a
        href="/"
        class="flex items-center gap-2.5 font-serif text-xl md:text-2xl text-white hover:text-gold-300 transition-colors"
      >
        <svg
          width="30"
          height="30"
          viewBox="0 0 64 64"
          aria-hidden="true"
          class="shrink-0"
        >
          <path
            d="M32 6 L56 16 V34 C56 46 45 55 32 60 C19 55 8 46 8 34 V16 Z"
            fill="#D69E2E"
          />
          <text
            x="32"
            y="40"
            font-family="Georgia,serif"
            font-size="20"
            font-weight="700"
            fill="#0F1D32"
            text-anchor="middle">FSO</text
          >
        </svg>
        <span>{SITE.shortName}</span>
      </a>

      <nav
        aria-label="Primary"
        class="hidden md:flex items-center gap-1 text-sm font-medium"
      >
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class:list={[
                'px-3 py-2 rounded-md transition-colors',
                isActive(link.href)
                  ? 'bg-navy-800 text-gold-300'
                  : 'text-white hover:bg-navy-800 hover:text-gold-300',
              ]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="/free-checklist"
          class:list={[
            'ml-2 px-3 py-2 rounded-md border font-semibold transition-colors',
            isActive('/free-checklist')
              ? 'bg-gold-500 text-navy-950 border-gold-500'
              : 'border-gold-500/70 text-gold-300 hover:bg-gold-500 hover:text-navy-950 hover:border-gold-500',
          ]}
          aria-current={isActive('/free-checklist') ? 'page' : undefined}
        >
          Free Checklist
        </a>
        <a
          href="/search"
          class="px-3 py-2 rounded-md text-white/90 hover:text-gold-300 transition-colors"
          aria-label="Search"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7" />
            <path stroke-linecap="round" d="m20 20-3.5-3.5" />
          </svg>
        </a>
      </nav>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden inline-flex items-center justify-center rounded-md p-2 text-white hover:bg-navy-800"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <span class="sr-only">Open menu</span>
        <svg
          class="h-6 w-6"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <nav
      id="mobile-menu"
      aria-label="Mobile"
      class="md:hidden hidden pb-3 space-y-1"
    >
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'block px-3 py-2 rounded-md text-sm font-medium',
              isActive(link.href)
                ? 'bg-navy-800 text-gold-300'
                : 'text-white hover:bg-navy-800 hover:text-gold-300',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/free-checklist"
        class:list={[
          'block px-3 py-2 rounded-md text-sm font-semibold border',
          isActive('/free-checklist')
            ? 'bg-gold-500 text-navy-950 border-gold-500'
            : 'border-gold-500/70 text-gold-300 hover:bg-gold-500 hover:text-navy-950',
        ]}
        aria-current={isActive('/free-checklist') ? 'page' : undefined}
      >
        Free Checklist
      </a>
      <a
        href="/search"
        class="block px-3 py-2 rounded-md text-sm font-medium text-white/90 hover:bg-navy-800 hover:text-gold-300"
      >
        Search
      </a>
    </nav>
  </div>
</header>

<script is:inline>
  // Rebind on every page-load so View Transitions don't leave the
  // toggle unbound.
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu || toggle.dataset.enhanced) return;
    toggle.dataset.enhanced = 'true';
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('hidden') === false;
      toggle.setAttribute('aria-expanded', String(open));
    });
  }
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
