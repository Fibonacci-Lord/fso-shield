---
import type { CollectionEntry } from 'astro:content';
import { CATEGORY_META } from '../content.config';
import { getArticleUrl } from '../utils/urls';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, category, featuredImage } =
  post.data;

const cat = CATEGORY_META[category];
const date = updatedDate ?? pubDate;
const href = getArticleUrl(post);
---

<article
  class="card group flex h-full flex-col overflow-hidden rounded-lg border-t-2 border-transparent hover:border-t-gold-500"
>
  {
    featuredImage && (
      <a href={href} class="block overflow-hidden">
        <img
          src={featuredImage}
          alt=""
          loading="lazy"
          class="w-full h-44 object-cover group-hover:scale-[1.015] transition-transform duration-500"
        />
      </a>
    )
  }
  <div class="flex flex-1 flex-col p-6">
    <div class="flex items-center gap-2">
      <a
        href={`/category/${category}`}
        class="eyebrow text-gold-700 hover:text-gold-600 transition-colors"
      >
        {cat.label}
      </a>
      <span class="text-navy-300" aria-hidden="true">·</span>
      <time
        datetime={date.toISOString()}
        class="text-xs uppercase tracking-wider text-navy-500 font-medium"
      >
        {date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        })}
      </time>
    </div>

    <h3 class="mt-3 font-serif text-[1.4rem] leading-tight text-navy-900">
      <a href={href} class="hover:text-gold-700 transition-colors">
        {title}
      </a>
    </h3>

    <p class="mt-2 text-[0.95rem] text-navy-800/80 leading-relaxed flex-1">
      {description}
    </p>

    <a
      href={href}
      class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-navy-800 group-hover:text-gold-700 transition-colors"
    >
      Read article
      <span
        class="transition-transform group-hover:translate-x-0.5"
        aria-hidden="true">→</span
      >
    </a>
  </div>
</article>
