---
/**
 * EmailSignup — three variants:
 *   card    (default)  rounded bone card, good for inline placement
 *   compact           smaller card, used in Footer
 *   band              full-bleed dark band, prominent homepage CTA
 */

type Variant = 'card' | 'compact' | 'band';

interface Props {
  heading?: string;
  description?: string;
  /** Legacy alias — maps to variant="compact" when true. */
  compact?: boolean;
  variant?: Variant;
  /** Button label. Defaults to "Subscribe". */
  buttonLabel?: string;
  /** Input placeholder. */
  placeholder?: string;
  /** Success message shown after the form submits successfully. */
  successMessage?: string;
  /** Footnote shown below the form. */
  footnote?: string;
  /** Hidden form input for tagging / source tracking in Kit. */
  source?: string;
}

const {
  heading,
  description,
  compact = false,
  variant = compact ? 'compact' : 'card',
  buttonLabel = 'Subscribe',
  placeholder,
  successMessage,
  footnote = 'No spam. Unsubscribe any time.',
  source,
} = Astro.props;

const resolvedHeading =
  heading ??
  (variant === 'band'
    ? 'FSO Field Notes'
    : 'Get the FSO Field Notes newsletter');

const resolvedDescription =
  description ??
  (variant === 'band'
    ? 'Weekly NISPOM and DCSA updates for working FSOs. One short email, no fluff.'
    : 'Weekly guidance on NISPOM, DCSA updates, CMMC for industrial security, and practical checklists for working FSOs.');

// Unique IDs per render — form can appear multiple times on one page.
const uid = crypto.randomUUID().slice(0, 8);
const headingId = `newsletter-heading-${uid}`;
const emailId = `newsletter-email-${uid}`;
---

{
  variant === 'band' ? (
    <!-- ============================================================
         Band variant — full-bleed dark band with editorial treatment
         ============================================================ -->
    <section
      class="hero-ink relative overflow-hidden border-t-4 border-gold-500"
      aria-labelledby={headingId}
    >
      <div
        class="hero-grid absolute inset-0 opacity-40"
        aria-hidden="true"
      />
      <div class="relative max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
        <div class="grid gap-10 md:grid-cols-2 md:items-center">
          <div>
            <p class="eyebrow text-gold-300">The Newsletter</p>
            <h2
              id={headingId}
              class="mt-3 font-serif text-4xl md:text-5xl text-white leading-[1.05] tracking-tight"
            >
              {resolvedHeading}
            </h2>
            <p class="mt-4 text-navy-100 text-lg leading-relaxed max-w-md">
              {resolvedDescription}
            </p>
          </div>

          <div class="md:pl-6">
            <form
              action="https://app.kit.com/forms/9353742/subscriptions"
              method="post"
              data-kit-form
              class="flex flex-col gap-3"
            >
              <label class="sr-only" for={emailId}>Email address</label>
              <input
                id={emailId}
                type="email"
                name="email_address"
                required
                autocomplete="email"
                placeholder={placeholder ?? 'you@company.com'}
                class="w-full rounded-md border border-white/20 bg-white/5 px-4 py-3 text-white placeholder:text-navy-200/70 focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-gold-400"
              />
              {source && (
                <input type="hidden" name="fields[source]" value={source} />
              )}
              <button
                type="submit"
                class="w-full rounded-md bg-gold-500 px-5 py-3 font-semibold text-navy-950 hover:bg-gold-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-navy-950 focus:ring-gold-400 transition-colors"
              >
                {buttonLabel}
              </button>
            </form>

            <div
              data-kit-success
              hidden
              class="mt-4 rounded-md border border-gold-400/40 bg-gold-500/10 px-4 py-3 text-gold-100"
            >
              {successMessage ? (
                <span set:html={successMessage} />
              ) : (
                <>
                  <strong class="text-white">Thanks!</strong> Check your email
                  to confirm your subscription.
                </>
              )}
            </div>
            <div
              data-kit-error
              hidden
              class="mt-4 rounded-md border border-red-400/40 bg-red-500/10 px-4 py-3 text-red-100"
            >
              Something went wrong. Please try again.
            </div>

            <p class="mt-3 text-xs text-navy-300/80">{footnote}</p>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <!-- ============================================================
         Card / compact variant — bone surface, rounded
         ============================================================ -->
    <section
      class:list={[
        'card rounded-lg border-t-2 border-t-gold-500',
        variant === 'compact' ? 'p-5' : 'p-6 md:p-8',
      ]}
      aria-labelledby={headingId}
    >
      <h2
        id={headingId}
        class:list={[
          'font-serif text-navy-900',
          variant === 'compact'
            ? 'text-xl'
            : 'text-2xl md:text-3xl leading-tight',
        ]}
      >
        {resolvedHeading}
      </h2>
      <p class="mt-2 text-navy-800/80 leading-relaxed">
        {resolvedDescription}
      </p>

      <form
        action="https://app.kit.com/forms/9353742/subscriptions"
        method="post"
        data-kit-form
        class="mt-5 flex flex-col gap-2"
      >
        <label class="sr-only" for={emailId}>Email address</label>
        <input
          id={emailId}
          type="email"
          name="email_address"
          required
          autocomplete="email"
          placeholder={placeholder ?? 'you@example.com'}
          class="w-full rounded-md border border-navy-200 bg-white px-4 py-2.5 text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500"
        />
        {source && (
          <input type="hidden" name="fields[source]" value={source} />
        )}
        <button
          type="submit"
          class="w-full rounded-md bg-gold-500 px-5 py-2.5 font-semibold text-navy-950 hover:bg-gold-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gold-500 transition-colors"
        >
          {buttonLabel}
        </button>
      </form>

      <div
        data-kit-success
        hidden
        class="mt-4 rounded-md border border-gold-300 bg-gold-100/70 px-4 py-3 text-navy-900"
      >
        {successMessage ? (
          <span set:html={successMessage} />
        ) : (
          <>
            <strong>Thanks!</strong> Check your email to confirm your
            subscription.
          </>
        )}
      </div>
      <div
        data-kit-error
        hidden
        class="mt-4 rounded-md border border-red-300 bg-red-50 px-4 py-3 text-red-900"
      >
        Something went wrong. Please try again.
      </div>

      <p class="mt-3 text-xs text-navy-700/70">{footnote}</p>
    </section>
  )
}
