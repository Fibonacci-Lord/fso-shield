---
interface Props {
  heading?: string;
  description?: string;
  compact?: boolean;
}

const {
  heading = 'Get the FSO Field Notes newsletter',
  description = 'Weekly guidance on NISPOM, DCSA updates, CMMC for industrial security, and practical checklists for working FSOs.',
  compact = false,
} = Astro.props;

// Unique IDs per render — EmailSignup can appear multiple times on one page
// (e.g., footer + article end) and duplicate IDs break accessibility.
const uid = crypto.randomUUID().slice(0, 8);
const headingId = `newsletter-heading-${uid}`;
const emailId = `newsletter-email-${uid}`;
---

<section
  class:list={[
    'rounded-lg border border-navy-200 bg-navy-50',
    compact ? 'p-5' : 'p-6 md:p-8',
  ]}
  aria-labelledby={headingId}
>
  <h2
    id={headingId}
    class:list={[
      'font-serif font-bold text-navy-800',
      compact ? 'text-xl' : 'text-2xl md:text-3xl',
    ]}
  >
    {heading}
  </h2>
  <p class="mt-2 text-navy-900/80">{description}</p>

  <form
    action="https://app.kit.com/forms/9353742/subscriptions"
    method="post"
    data-kit-form
    class="mt-4 flex flex-col gap-2"
  >
    <label class="sr-only" for={emailId}>Email address</label>
    <input
      id={emailId}
      type="email"
      name="email_address"
      required
      autocomplete="email"
      placeholder="you@example.com"
      class="w-full rounded border border-navy-300 bg-white px-4 py-2.5 text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500"
    />
    <button
      type="submit"
      class="w-full rounded bg-gold-500 px-5 py-2.5 font-semibold text-navy-900 hover:bg-gold-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gold-500 transition-colors"
    >Subscribe</button>
  </form>

  <div
    data-kit-success
    hidden
    class="mt-4 rounded border border-green-300 bg-green-50 px-4 py-3 text-green-900"
  >
    <strong>Thanks!</strong> Check your email to confirm your subscription.
  </div>
  <div
    data-kit-error
    hidden
    class="mt-4 rounded border border-red-300 bg-red-50 px-4 py-3 text-red-900"
  >
    Something went wrong. Please try again.
  </div>

  <p class="mt-2 text-xs text-navy-700/70">
    No spam. Unsubscribe any time.
  </p>
</section>
