---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import JsonLd from '../components/JsonLd.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Free checklist', url: '/free-checklist', current: true },
];

const whatsInside = [
  'FSO appointment, CDSE training, and DCSA notification',
  'SF-312 execution and initial security briefings',
  'Annual refresher training and debriefings',
  'Insider Threat Program and awareness training',
  'Adverse information reporting and self-inspection cadence',
  'Container storage, combination changes, and SF-700 tracking',
  'Visit authorization letters through DISS',
  'Foreign travel reporting under SEAD-3',
];

// Unique form IDs to avoid collisions with other EmailSignup instances.
const uid = 'lm';
const emailId = `lead-magnet-email-${uid}`;
---

<BaseLayout
  title="Is Your Facility Ready for a DCSA Assessment? — Free 15-Item Quick-Check"
  description="Free pre-assessment gut check for Facility Security Officers. 15 items covering findings DCSA cites in 80% of security vulnerability assessments. Know where you stand before the assessor does."
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <!-- ============================================================
       Hero — deep ink band, form above the fold
       ============================================================ -->
  <section
    class="hero-ink relative overflow-hidden border-b-4 border-gold-500"
  >
    <div class="hero-grid absolute inset-0 opacity-40" aria-hidden="true"></div>

    <div
      class="relative max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-24"
    >
      <Breadcrumbs items={breadcrumbItems} tone="light" />

      <div class="mt-6 grid gap-10 md:grid-cols-[1.1fr_1fr] md:items-start">
        <div>
          <ScrollReveal>
            <p class="eyebrow text-gold-300">Free resource</p>
          </ScrollReveal>

          <ScrollReveal delay={80}>
            <h1
              class="mt-4 font-serif text-white leading-[1.03] tracking-[-0.025em]
                     text-[2.75rem] sm:text-[3.5rem] md:text-[4rem] lg:text-[4.25rem]"
            >
              Is your facility ready for a DCSA assessment?
            </h1>
          </ScrollReveal>

          <ScrollReveal delay={160}>
            <p class="mt-6 text-lg md:text-xl text-navy-100 max-w-xl leading-relaxed">
              15-item quick check covering the findings DCSA cites in 80% of
              security vulnerability assessments. Takes 10 minutes. Know where
              you stand before the assessor does.
            </p>
          </ScrollReveal>
        </div>

        <!-- Signup form card (lifts over dark background) -->
        <ScrollReveal delay={240}>
          <div
            class="rounded-lg border border-white/10 bg-white/[0.04] backdrop-blur-sm p-6 md:p-7"
          >
            <p class="eyebrow text-gold-300">Get the PDF</p>
            <h2
              class="mt-2 font-serif text-2xl md:text-3xl text-white leading-snug"
            >
              Send me the checklist.
            </h2>
            <p class="mt-2 text-sm text-navy-200 leading-relaxed">
              Enter your email and we'll send the 15-item PDF straight to your
              inbox.
            </p>

            <form
              action="https://app.kit.com/forms/9362363/subscriptions"
              method="post"
              data-kit-form
              class="mt-5 flex flex-col gap-3"
            >
              <label class="sr-only" for={emailId}>Email address</label>
              <input
                id={emailId}
                type="email"
                name="email_address"
                required
                autocomplete="email"
                placeholder="you@company.com"
                class="w-full rounded-md border border-white/20 bg-navy-950/40 px-4 py-3 text-white placeholder:text-navy-200/70 focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-gold-400"
              />
              <!-- Kit tagging hint: subscriber source is lead magnet. Wire in Kit automation. -->
              <input
                type="hidden"
                name="fields[source]"
                value="lead-magnet-quick-check"
              />
              <button
                type="submit"
                class="w-full rounded-md bg-gold-500 px-5 py-3 font-semibold text-navy-950 hover:bg-gold-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-navy-950 focus:ring-gold-400 transition-colors"
              >
                Send me the checklist
              </button>
            </form>

            <div
              data-kit-success
              hidden
              class="mt-4 rounded-md border border-gold-400/40 bg-gold-500/10 px-4 py-3 text-gold-100 leading-relaxed"
            >
              <strong class="text-white">Check your inbox</strong> for your
              Quick-Check. When you're ready for the full 77-item inspection —{' '}
              <a
                href="/templates"
                class="underline underline-offset-2 hover:text-white transition-colors"
                >get the Self-Inspection Checklist ($39)</a
              > or{' '}
              <a
                href="/assessment-kit"
                class="underline underline-offset-2 hover:text-white transition-colors"
                >get the Complete Assessment Kit ($297)</a
              > and close every gap at once.
            </div>
            <div
              data-kit-error
              hidden
              class="mt-4 rounded-md border border-red-400/40 bg-red-500/10 px-4 py-3 text-red-100"
            >
              Something went wrong. Please try again.
            </div>

            <p class="mt-4 text-xs text-navy-300/80 leading-relaxed">
              No spam. Unsubscribe any time. The full 77-item checklist is
              available at
              <a
                href="/templates"
                class="underline underline-offset-2 hover:text-gold-300 transition-colors"
                >/templates</a
              >.
            </p>
          </div>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- ============================================================
       What's inside
       ============================================================ -->
  <section
    class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-20"
    aria-labelledby="whats-inside-heading"
  >
    <div class="grid gap-12 md:grid-cols-[1fr_1.3fr] md:items-start">
      <ScrollReveal>
        <div>
          <p class="eyebrow text-gold-700">Inside the PDF</p>
          <h2
            id="whats-inside-heading"
            class="mt-3 font-serif text-3xl md:text-4xl text-navy-900 leading-tight"
          >
            What you'll find inside.
          </h2>
          <p class="mt-4 text-navy-800/85 leading-relaxed">
            Eight pages. Fifteen items. Each one maps to the NISPOM section
            DCSA will ask about, with a one-line note on the evidence the
            assessor actually looks for.
          </p>

          <div class="mt-8 rounded-md border border-navy-200 bg-navy-100/60 p-5">
            <p class="eyebrow text-navy-700">Who this is for</p>
            <p class="mt-2 text-navy-900 leading-relaxed">
              FSOs at cleared defense contractors preparing for a DCSA security
              vulnerability assessment — especially newly appointed FSOs and
              teams that inherited a program with undocumented gaps.
            </p>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <ul class="space-y-3" role="list">
          {
            whatsInside.map((item) => (
              <li class="flex items-start gap-3 rounded-md border border-navy-100 bg-bone p-4">
                <svg
                  class="shrink-0 mt-0.5 h-5 w-5 text-gold-500"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path
                    fill-rule="evenodd"
                    d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.07 7.115a1 1 0 0 1-1.42.007L3.29 8.91a1 1 0 1 1 1.42-1.408l4.22 4.257 6.36-6.4a1 1 0 0 1 1.414-.07z"
                    clip-rule="evenodd"
                  />
                </svg>
                <span class="text-navy-900 leading-relaxed">{item}</span>
              </li>
            ))
          }
        </ul>
      </ScrollReveal>
    </div>
  </section>

  <!-- ============================================================
       Upsell — full checklist or the complete kit
       ============================================================ -->
  <section
    class="bg-navy-100/70 border-y border-navy-200"
    aria-labelledby="upsell-heading"
  >
    <div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
      <ScrollReveal>
        <p class="eyebrow text-gold-700">Ready for the full version?</p>
        <h2
          id="upsell-heading"
          class="mt-3 font-serif text-3xl md:text-4xl text-navy-900 leading-tight max-w-2xl"
        >
          Close every gap — not just the top 15.
        </h2>
      </ScrollReveal>

      <ScrollReveal delay={120}>
        <div
          class="mt-10 grid gap-8 md:grid-cols-2 rounded-lg card-featured card p-6 md:p-10"
        >
          <div>
            <p class="eyebrow text-navy-700">The full checklist</p>
            <p class="mt-2 font-serif text-2xl text-navy-900">
              77 items · 9 sections · $39
            </p>
            <ul class="mt-4 space-y-2 text-navy-800/85 text-[0.95rem] leading-relaxed" role="list">
              <li>All 9 NISPOM sections under 32 CFR Part 117</li>
              <li>Findings summary table and corrective-action tracker</li>
              <li>Inspector certification page</li>
              <li>Detailed assessor annotations per item</li>
              <li>Instant download, lifetime updates</li>
            </ul>
            <a
              href="/templates"
              class="mt-6 inline-flex items-center gap-1 rounded-md bg-navy-800 text-white px-5 py-2.5 font-semibold hover:bg-navy-900 transition-colors"
            >
              Get the checklist — $39
              <span aria-hidden="true">→</span>
            </a>
          </div>

          <div class="md:border-l md:border-navy-200 md:pl-8">
            <div class="flex items-center gap-3">
              <p class="eyebrow text-gold-700">The complete kit</p>
              <span class="inline-block rounded-full bg-gold-500 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-navy-950">
                Best value
              </span>
            </div>
            <p class="mt-2 font-serif text-2xl text-navy-900">
              4 templates · 1 download · $297
            </p>
            <ul class="mt-4 space-y-2 text-navy-800/85 text-[0.95rem] leading-relaxed" role="list">
              <li>The full 77-item Self-Inspection Checklist</li>
              <li>Complete Insider Threat Program kit (the #1 finding)</li>
              <li>12-section Standard Practice Procedures template</li>
              <li>Four ready-to-deliver briefing decks</li>
              <li>Everything DCSA expects to see — one download</li>
            </ul>

            <a
              href="/assessment-kit"
              class="mt-6 inline-flex items-center gap-1 rounded-md bg-gold-500 text-navy-950 px-5 py-2.5 font-semibold hover:bg-gold-400 transition-colors"
            >
              Get the Complete Assessment Kit — $297
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>
