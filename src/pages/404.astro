---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you requested could not be found."
  noindex
>
  <section
    class="max-w-2xl mx-auto px-6 sm:px-8 lg:px-12 py-28 md:py-36 text-center"
  >
    <p class="eyebrow text-gold-700">404</p>
    <h1
      class="mt-4 font-serif text-5xl md:text-6xl text-navy-900 leading-[1.05] tracking-[-0.025em]"
    >
      Page not found.
    </h1>
    <p class="mt-5 text-lg text-navy-800/80 leading-relaxed">
      The page you're looking for doesn't exist, was moved, or is no longer
      available.
    </p>
    <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded-md bg-navy-900 text-white px-6 py-3 font-semibold hover:bg-navy-950 transition-colors"
        >Go home</a
      >
      <a
        href="/search"
        class="inline-flex items-center justify-center rounded-md border border-navy-300 px-6 py-3 font-semibold text-navy-800 hover:bg-bone transition-colors"
        >Search the site</a
      >
    </div>
  </section>
</BaseLayout>
