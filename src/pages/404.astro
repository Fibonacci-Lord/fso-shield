---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you requested could not be found."
  noindex
>
  <section class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <p
      class="inline-block text-xs font-semibold uppercase tracking-widest text-gold-700"
    >
      404
    </p>
    <h1 class="mt-3 font-serif text-4xl md:text-5xl text-navy-800">
      Page not found
    </h1>
    <p class="mt-4 text-navy-700">
      The page you're looking for doesn't exist, was moved, or is no longer
      available.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center rounded bg-navy-700 text-white px-6 py-3 font-semibold hover:bg-navy-800"
        >Go home</a
      >
      <a
        href="/search"
        class="inline-flex items-center justify-center rounded border border-navy-300 px-6 py-3 font-semibold text-navy-700 hover:bg-navy-50"
        >Search the site</a
      >
    </div>
  </section>
</BaseLayout>
