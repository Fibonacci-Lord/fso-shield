---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import JsonLd from '../components/JsonLd.astro';

// Replace with your real Formspree endpoint.
// Get yours at https://formspree.io/ — format: https://formspree.io/f/xxxxxxxx
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/REPLACE_WITH_YOUR_ID';

const needsOptions = [
  'FSO Support / Consulting',
  'CMMC Compliance',
  'Facility Clearance',
  'NISPOM Compliance',
  'Security Training',
  'Other',
];

const employeeRanges = ['1-10', '11-50', '51-200', '200+'];

const budgetRanges = [
  'Under $5K',
  '$5K - $15K',
  '$15K - $50K',
  '$50K+',
  'Not sure yet',
];

const timelineOptions = [
  'Urgent — within 30 days',
  '1-3 months',
  '3-6 months',
  'Just exploring',
];

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Contact', url: '/contact', current: true },
];

const inputClass =
  'mt-1 block w-full rounded border border-navy-300 bg-white px-4 py-2.5 text-navy-900 placeholder:text-navy-400 focus:outline-none focus:ring-2 focus:ring-gold-500 focus:border-gold-500';
const labelClass = 'block text-sm font-semibold text-navy-800';
const helpClass = 'mt-1 text-xs text-navy-600';
---

<BaseLayout
  title="Contact"
  description="Get help with NISPOM compliance, CMMC certification, facility clearance, and FSO support. Tell us about your situation."
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <section class="bg-navy-700 text-white border-b-4 border-gold-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <Breadcrumbs items={breadcrumbItems} />
      <h1 class="mt-3 font-serif text-4xl md:text-5xl text-white leading-tight">
        Contact
      </h1>
      <p class="mt-4 text-lg text-navy-100 max-w-2xl">
        Need help with NISPOM compliance, CMMC certification, or facility
        clearance? Tell us about your situation and we'll connect you with the
        right expert.
      </p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <form
      action={FORMSPREE_ENDPOINT}
      method="POST"
      class="rounded-lg border border-navy-100 bg-white shadow-sm p-6 md:p-8 space-y-6"
      novalidate
    >
      <input type="hidden" name="_subject" value="New lead — FSO Training Hub" />
      <!-- Formspree honeypot anti-spam field -->
      <input
        type="text"
        name="_gotcha"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
        aria-hidden="true"
      />

      <div class="grid gap-5 md:grid-cols-2">
        <div>
          <label class={labelClass} for="company">
            Company name <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">required</span>
          </label>
          <input
            id="company"
            name="company"
            type="text"
            required
            autocomplete="organization"
            class={inputClass}
          />
        </div>

        <div>
          <label class={labelClass} for="name">
            Contact name <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">required</span>
          </label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class={inputClass}
          />
        </div>

        <div>
          <label class={labelClass} for="email">
            Email <span class="text-red-600" aria-hidden="true">*</span>
            <span class="sr-only">required</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class={inputClass}
          />
        </div>

        <div>
          <label class={labelClass} for="phone">Phone</label>
          <input
            id="phone"
            name="phone"
            type="tel"
            autocomplete="tel"
            class={inputClass}
          />
        </div>

        <div>
          <label class={labelClass} for="cage">
            CAGE code
            <span class="ml-1 font-normal text-navy-500">(optional)</span>
          </label>
          <input
            id="cage"
            name="cage_code"
            type="text"
            maxlength="5"
            pattern="[A-Za-z0-9]{5}"
            inputmode="text"
            autocapitalize="characters"
            aria-describedby="cage-help"
            class={`${inputClass} uppercase tracking-widest`}
          />
          <p id="cage-help" class={helpClass}>
            Your 5-character Commercial and Government Entity code.
          </p>
        </div>

        <div>
          <label class={labelClass} for="employees">
            Number of employees
          </label>
          <select id="employees" name="employees" class={inputClass}>
            <option value="">Select a range…</option>
            {employeeRanges.map((range) => (
              <option value={range}>{range}</option>
            ))}
          </select>
        </div>
      </div>

      <fieldset>
        <legend class={labelClass}>
          What help do you need?
          <span class="ml-1 font-normal text-navy-500">
            (select all that apply)
          </span>
        </legend>
        <div class="mt-2 grid gap-2 sm:grid-cols-2">
          {needsOptions.map((option) => (
            <label class="flex items-start gap-2 rounded border border-navy-100 px-3 py-2 hover:border-navy-300 cursor-pointer">
              <input
                type="checkbox"
                name="needs[]"
                value={option}
                class="mt-0.5 h-4 w-4 rounded border-navy-300 text-gold-500 focus:ring-gold-500"
              />
              <span class="text-sm text-navy-900">{option}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <div class="grid gap-5 md:grid-cols-2">
        <div>
          <label class={labelClass} for="budget">Budget range</label>
          <select id="budget" name="budget" class={inputClass}>
            <option value="">Select a budget…</option>
            {budgetRanges.map((range) => (
              <option value={range}>{range}</option>
            ))}
          </select>
        </div>

        <div>
          <label class={labelClass} for="timeline">Timeline</label>
          <select id="timeline" name="timeline" class={inputClass}>
            <option value="">Select a timeline…</option>
            {timelineOptions.map((option) => (
              <option value={option}>{option}</option>
            ))}
          </select>
        </div>
      </div>

      <div>
        <label class={labelClass} for="message">
          Brief description of your needs
        </label>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="A few sentences on where you are today and what you're trying to accomplish."
          class={inputClass}></textarea>
      </div>

      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 pt-2">
        <p class="text-xs text-navy-600">
          Your information is used only to respond to this inquiry and is
          never sold.
        </p>
        <button
          type="submit"
          class="inline-flex items-center justify-center rounded bg-gold-500 px-6 py-3 font-semibold text-navy-900 hover:bg-gold-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gold-500 transition-colors"
        >
          Send inquiry
        </button>
      </div>
    </form>
  </section>
</BaseLayout>
