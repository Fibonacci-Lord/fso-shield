---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import JsonLd from '../../components/JsonLd.astro';
import EmailSignup from '../../components/EmailSignup.astro';
import { CATEGORY_META, categorySlugs, type Category } from '../../content.config';

export async function getStaticPaths() {
  return categorySlugs.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params as { category: Category };
const meta = CATEGORY_META[category];

const posts = (
  await getCollection('blog', (p) => p.data.category === category && !p.data.draft)
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: meta.label, url: `/category/${category}`, current: true },
];
---

<BaseLayout
  title={meta.label}
  description={meta.description}
  keywords={[meta.label]}
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <section class="bg-navy-700 text-white border-b-4 border-gold-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <Breadcrumbs items={breadcrumbItems} />
      <h1
        class="mt-3 font-serif text-4xl md:text-5xl text-white leading-tight"
      >
        {meta.label}
      </h1>
      <p class="mt-4 text-lg text-navy-100 max-w-2xl">{meta.description}</p>
      <p class="mt-4 text-sm">
        <a
          href={meta.path}
          class="text-gold-300 hover:text-gold-200 underline underline-offset-2"
        >
          See the {meta.label} pillar overview →
        </a>
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    {
      posts.length === 0 ? (
        <p class="text-navy-600">
          No articles have been published in this category yet.
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      )
    }
  </section>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
    <EmailSignup />
  </section>
</BaseLayout>
