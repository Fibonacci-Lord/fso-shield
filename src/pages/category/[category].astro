---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import JsonLd from '../../components/JsonLd.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import EmailSignup from '../../components/EmailSignup.astro';
import {
  CATEGORY_META,
  categorySlugs,
  type Category,
} from '../../content.config';

export async function getStaticPaths() {
  return categorySlugs.map((category) => ({
    params: { category },
  }));
}

const { category } = Astro.params as { category: Category };
const meta = CATEGORY_META[category];

const posts = (
  await getCollection(
    'blog',
    (p) => p.data.category === category && !p.data.draft
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: meta.label, url: `/category/${category}`, current: true },
];
---

<BaseLayout
  title={meta.label}
  description={meta.description}
  keywords={[meta.label]}
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <section
    class="hero-ink relative overflow-hidden border-b-4 border-gold-500"
  >
    <div class="hero-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
    <div
      class="relative max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-24"
    >
      <Breadcrumbs items={breadcrumbItems} tone="light" />
      <ScrollReveal>
        <p class="eyebrow mt-5 text-gold-300">Category archive</p>
      </ScrollReveal>
      <ScrollReveal delay={80}>
        <h1
          class="mt-3 font-serif text-white leading-[1.05] tracking-[-0.025em]
                 text-[2.75rem] sm:text-[3.25rem] md:text-[4rem] max-w-[20ch]"
        >
          {meta.label}
        </h1>
      </ScrollReveal>
      <ScrollReveal delay={160}>
        <p
          class="mt-5 text-lg md:text-xl text-navy-100 max-w-2xl leading-relaxed"
        >
          {meta.description}
        </p>
      </ScrollReveal>
      <ScrollReveal delay={240}>
        <p class="mt-4 text-sm">
          <a
            href={meta.path}
            class="text-gold-300 hover:text-gold-200 underline underline-offset-2"
          >
            See the {meta.label} pillar overview →
          </a>
        </p>
      </ScrollReveal>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-16">
    {
      posts.length === 0 ? (
        <p class="text-navy-700">
          No articles have been published in this category yet.
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post, i) => (
            <ScrollReveal delay={i * 80}>
              <ArticleCard post={post} />
            </ScrollReveal>
          ))}
        </div>
      )
    }
  </section>

  <section class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 pb-8">
    <EmailSignup />
  </section>
</BaseLayout>
