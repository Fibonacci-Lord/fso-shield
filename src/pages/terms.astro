---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms" description="Terms of use.">
  <section class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
    <p class="eyebrow text-gold-700">Legal</p>
    <h1
      class="mt-3 font-serif text-5xl md:text-6xl text-navy-900 leading-[1.05] tracking-[-0.025em]"
    >
      Terms.
    </h1>
    <div class="prose-article mt-10">
      {/* Replace with your own terms of use. */}
    </div>
  </section>
</BaseLayout>
