---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import JsonLd from '../components/JsonLd.astro';
import ScrollReveal from '../components/ScrollReveal.astro';

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Prepare', url: '/prepare', current: true },
];

const steps = [
  {
    n: 1,
    eyebrow: 'Know what they\u2019ll check',
    title: 'Understand the DCSA security vulnerability assessment.',
    body: 'DCSA assesses your program against 32 CFR Part 117. They review your Standard Practice Procedures, verify your Insider Threat Program, walk your self-inspection records, and interview your KMPs. The assessment is scheduled — but what gets cited isn\u2019t.',
    ctas: [
      { href: '/free-checklist', label: 'Download the free 15-item Quick-Check', style: 'ghost' },
      {
        href: 'https://fsoshield.lemonsqueezy.com/checkout/buy/efb06b45-4466-42b3-b416-8508f160e140',
        label: 'Get the full 77-item Self-Inspection Checklist — $39',
        style: 'solid',
      },
    ],
  },
  {
    n: 2,
    eyebrow: 'Fix your documentation',
    title: 'The three documents every assessor reviews.',
    body: 'Your Standard Practice Procedures. Your Insider Threat Program documentation. Your self-inspection records. Gaps in these three are the findings DCSA cites most often — and the ones easiest to close before the assessor arrives.',
    ctas: [
      {
        href: 'https://fsoshield.lemonsqueezy.com/checkout/buy/640d3c96-2979-4a9e-966b-9780e81405f1',
        label: 'Get the SPP Template — $149',
        style: 'solid',
      },
      {
        href: 'https://fsoshield.lemonsqueezy.com/checkout/buy/bd3b9ee5-f0d9-4719-9219-7b2cad7c06d4',
        label: 'Get the Insider Threat Program Kit — $89',
        style: 'solid',
      },
    ],
  },
  {
    n: 3,
    eyebrow: 'Deliver required briefings',
    title: 'Verify every briefing is documented.',
    body: 'DCSA will verify that initial briefings, annual refreshers, and insider threat training have been delivered and documented. Missing signatures or undated SF-312 forms trigger findings — even if the training happened.',
    ctas: [
      {
        href: 'https://fsoshield.lemonsqueezy.com/checkout/buy/193f907b-2e5c-4790-9164-33948dd6d5a7',
        label: 'Get the Briefing Slide Decks — $59',
        style: 'solid',
      },
    ],
  },
  {
    n: 4,
    eyebrow: 'Get everything at once',
    title: 'Stop buying one piece at a time.',
    body: 'Every template, checklist, and briefing deck an FSO needs — in one download. One price. Zero gaps. This is what your program looks like when it\u2019s ready.',
    ctas: [
      { href: '/assessment-kit', label: 'Get the Complete Assessment Kit — $297', style: 'hero' },
    ],
  },
];

const faqItems = [
  {
    question: 'How much notice does DCSA give before an assessment?',
    answer:
      'Routine security vulnerability assessments are typically scheduled 30 to 60 days in advance through your Industrial Security Representative. Enhanced assessments or no-notice visits are possible for cause.',
  },
  {
    question: 'What happens if I get findings?',
    answer:
      'Each finding triggers a corrective action timeline. Minor findings can be closed with documentation updates. Major findings or repeat findings can escalate — in serious cases, to an unfavorable determination that puts your Facility Clearance at risk.',
  },
  {
    question: 'How long should preparation take?',
    answer:
      'Plan on 4–8 weeks of dedicated prep time for a first-time assessment, less if your documentation is already current. Most findings come from stale paperwork, not missing programs.',
  },
];
---

<BaseLayout
  title="Prepare for Your DCSA Assessment — The FSO's Playbook"
  description="Step-by-step: what DCSA checks, what to fix before they arrive, and how to close documentation gaps fast. Templates and checklists aligned to 32 CFR Part 117."
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />
  <JsonLd type="FAQPage" data={{ questions: faqItems }} />

  <!-- ============================================================
       Hero
       ============================================================ -->
  <section
    class="hero-ink relative overflow-hidden border-b-4 border-gold-500"
  >
    <div class="hero-grid absolute inset-0 opacity-40" aria-hidden="true"></div>

    <div
      class="relative max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-24"
    >
      <Breadcrumbs items={breadcrumbItems} tone="light" />

      <ScrollReveal>
        <p class="mt-6 eyebrow text-gold-300">The FSO's playbook</p>
      </ScrollReveal>

      <ScrollReveal delay={80}>
        <h1
          class="mt-4 font-serif text-white leading-[1.03] tracking-[-0.025em]
                 text-[2.75rem] sm:text-[3.5rem] md:text-[4.25rem] lg:text-[4.75rem]
                 max-w-[18ch]"
        >
          Prepare for your DCSA assessment.
        </h1>
      </ScrollReveal>

      <ScrollReveal delay={160}>
        <p class="mt-6 text-lg md:text-xl text-navy-100 max-w-2xl leading-relaxed">
          Step-by-step: what to do before the assessor arrives, what they'll
          check, and how to close gaps fast.
        </p>
      </ScrollReveal>

      <ScrollReveal delay={240}>
        <div class="mt-10 flex flex-col sm:flex-row gap-3">
          <a
            href="#step-1"
            class="inline-flex items-center justify-center rounded-md bg-gold-500
                   px-7 py-3.5 font-semibold text-navy-950 hover:bg-gold-400
                   transition-colors"
          >
            Start with Step 1 ↓
          </a>
          <a
            href="/assessment-kit"
            class="inline-flex items-center justify-center rounded-md
                   border border-gold-400/70 bg-transparent px-7 py-3.5
                   font-semibold text-gold-300 hover:bg-navy-900
                   hover:border-gold-400 transition-colors"
          >
            Skip ahead — get the Kit →
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- ============================================================
       Four steps
       ============================================================ -->
  <div class="max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 py-20 space-y-16">
    {
      steps.map((step, i) => (
        <ScrollReveal>
          <section id={`step-${step.n}`} class="scroll-mt-24">
            <div class="flex items-center gap-4">
              <span class="shrink-0 flex h-12 w-12 items-center justify-center rounded-full bg-navy-900 text-gold-400 font-serif text-xl font-semibold">
                {step.n}
              </span>
              <p class="eyebrow text-gold-700">{step.eyebrow}</p>
            </div>

            <h2 class="mt-4 font-serif text-3xl md:text-4xl text-navy-900 leading-tight max-w-3xl">
              {step.title}
            </h2>

            <p class="mt-5 text-lg text-navy-800/90 leading-relaxed max-w-3xl">
              {step.body}
            </p>

            <div class="mt-6 flex flex-col sm:flex-row flex-wrap gap-3">
              {step.ctas.map((cta) => {
                const isHero = cta.style === 'hero';
                const isSolid = cta.style === 'solid';
                const cls = isHero
                  ? 'inline-flex items-center justify-center rounded-md bg-gold-500 px-6 py-3 text-base font-semibold text-navy-950 hover:bg-gold-400 transition-colors shadow-card'
                  : isSolid
                    ? 'inline-flex items-center justify-center rounded-md bg-navy-900 px-5 py-2.5 text-sm font-semibold text-white hover:bg-navy-950 transition-colors'
                    : 'inline-flex items-center justify-center rounded-md border border-navy-300 bg-white px-5 py-2.5 text-sm font-semibold text-navy-900 hover:border-gold-500 hover:text-gold-700 transition-colors';
                return (
                  <a
                    href={cta.href}
                    rel={cta.href.startsWith('http') ? 'noopener' : undefined}
                    class={cls}
                  >
                    {cta.label}
                    <span class="ml-1" aria-hidden="true">
                      →
                    </span>
                  </a>
                );
              })}
            </div>

            {i < steps.length - 1 && <hr class="mt-12 border-navy-100" />}
          </section>
        </ScrollReveal>
      ))
    }
  </div>

  <!-- ============================================================
       FAQ
       ============================================================ -->
  <section
    class="bg-navy-100/70 border-y border-navy-200"
    aria-labelledby="prepare-faq"
  >
    <div class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
      <ScrollReveal>
        <p class="eyebrow text-gold-700">Questions</p>
        <h2
          id="prepare-faq"
          class="mt-3 font-serif text-3xl md:text-4xl text-navy-900 leading-tight"
        >
          About the assessment.
        </h2>
      </ScrollReveal>

      <dl class="mt-10 space-y-6">
        {
          faqItems.map((item, i) => (
            <ScrollReveal delay={i * 60}>
              <div class="rounded-md border border-navy-200 bg-bone p-6">
                <dt class="font-serif text-xl text-navy-900 leading-snug">
                  {item.question}
                </dt>
                <dd class="mt-2 text-navy-800/85 leading-relaxed">
                  {item.answer}
                </dd>
              </div>
            </ScrollReveal>
          ))
        }
      </dl>
    </div>
  </section>
</BaseLayout>
