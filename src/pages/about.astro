---
import BaseLayout from '../layouts/BaseLayout.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { SITE } from '../consts';
---

<BaseLayout
  title="About"
  description={`About ${SITE.name} — practical industrial security training and NISPOM compliance resources for Facility Security Officers.`}
>
  <section class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
    <p class="eyebrow text-gold-700">About</p>
    <h1
      class="mt-3 font-serif text-5xl md:text-6xl text-navy-900 leading-[1.05] tracking-[-0.025em]"
    >
      About {SITE.name}.
    </h1>
    <div class="prose-article mt-10">
      {/* Add your own About content here. */}
    </div>
    <div class="mt-14">
      <EmailSignup />
    </div>
  </section>
</BaseLayout>
