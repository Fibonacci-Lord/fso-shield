---
import PillarPage from '../../layouts/PillarPage.astro';
---

<PillarPage category="cmmc" title="CMMC for FSOs">
  <aside
    class="not-prose mb-12 rounded-lg border border-teal-200 bg-teal-50/60 border-l-4 border-l-teal-600 p-6 md:p-8"
    aria-label="Start with the workbook"
  >
    <div class="grid gap-6 md:grid-cols-[1.3fr_auto] md:items-center">
      <div>
        <p class="eyebrow text-teal-700">Start with the workbook</p>
        <p
          class="mt-2 font-serif text-2xl md:text-[1.7rem] text-navy-900 leading-snug"
        >
          The CMMC Level 2 Self-Assessment Workbook walks you through all 110
          NIST SP 800-171 controls with evidence guidance, assessor insights,
          and an SPRS score calculator.
        </p>
      </div>
      <div class="md:text-right">
        <a
          href="/cmmc-workbook"
          class="inline-flex items-center justify-center rounded-md bg-teal-700 px-6 py-3 font-semibold text-white hover:bg-teal-800 transition-colors whitespace-nowrap"
        >
          $147 — Get it now
          <span class="ml-1" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </aside>
</PillarPage>
