---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import JsonLd from '../components/JsonLd.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import {
  SUBSCRIBER_COUNT,
  TESTIMONIALS,
  RECENT_ISSUES,
} from '../data/newsletter';

const subscriberLine =
  SUBSCRIBER_COUNT && SUBSCRIBER_COUNT > 0
    ? `Join ${SUBSCRIBER_COUNT.toLocaleString()} security professionals`
    : 'Join security professionals';

const benefits = [
  'NISPOM and DCSA regulation changes that affect your program',
  'Practical compliance tips from an experienced FSO',
  'Templates, checklists, and tools to make your job easier',
];

const recentIssues = [...RECENT_ISSUES]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 3);

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Newsletter', url: '/newsletter', current: true },
];
---

<BaseLayout
  title="The FSO Brief — Weekly NISPOM Compliance Updates"
  description="Join security professionals getting one regulation update, one practical tip, and one resource every week. A weekly email for working FSOs."
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <!-- ============================================================
       Hero + primary CTA
       ============================================================ -->
  <section
    class="hero-ink relative overflow-hidden border-b-4 border-gold-500"
  >
    <div class="hero-grid absolute inset-0 opacity-40" aria-hidden="true"></div>

    <div
      class="relative max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-24"
    >
      <Breadcrumbs items={breadcrumbItems} tone="light" />

      <ScrollReveal>
        <p class="eyebrow mt-5 text-gold-300">The FSO Brief</p>
      </ScrollReveal>

      <ScrollReveal delay={80}>
        <h1
          class="mt-3 font-serif text-white leading-[1.03] tracking-[-0.025em]
                 text-[2.5rem] sm:text-[3.25rem] md:text-[4rem] lg:text-[4.5rem]"
        >
          Weekly NISPOM compliance updates you can actually use.
        </h1>
      </ScrollReveal>

      <ScrollReveal delay={160}>
        <p
          class="mt-5 text-lg md:text-xl text-navy-100 max-w-2xl leading-relaxed"
        >
          {subscriberLine} getting one regulation update, one practical tip,
          and one resource every week.
        </p>
      </ScrollReveal>

      <ScrollReveal delay={240}>
        <form
          action="https://app.kit.com/forms/9353742/subscriptions"
          method="post"
          data-kit-form
          class="mt-10 flex flex-col gap-3 max-w-xl"
        >
          <label class="sr-only" for="newsletter-email">Email address</label>
          <input
            id="newsletter-email"
            type="email"
            name="email_address"
            required
            autocomplete="email"
            placeholder="you@company.com"
            class="w-full rounded-md border border-white/20 bg-white/5 px-4 py-3 text-white placeholder:text-navy-200/70 focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-gold-400"
          />
          <button
            type="submit"
            class="w-full rounded-md bg-gold-500 px-6 py-3 font-semibold text-navy-950 hover:bg-gold-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-navy-950 focus:ring-gold-400 transition-colors"
          >
            Subscribe free
          </button>
        </form>

        <div
          data-kit-success
          hidden
          class="mt-4 rounded-md border border-gold-400/40 bg-gold-500/10 px-4 py-3 text-gold-100 max-w-xl"
        >
          <strong class="text-white">Thanks!</strong> Check your email to
          confirm your subscription.
        </div>
        <div
          data-kit-error
          hidden
          class="mt-4 rounded-md border border-red-400/40 bg-red-500/10 px-4 py-3 text-red-100 max-w-xl"
        >
          Something went wrong. Please try again.
        </div>

        <p class="mt-3 text-xs text-navy-300/80">
          One email per week. No spam. Unsubscribe any time.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ============================================================
       What you'll get
       ============================================================ -->
  <section
    class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-20"
    aria-labelledby="benefits-heading"
  >
    <ScrollReveal>
      <h2
        id="benefits-heading"
        class="font-serif text-3xl md:text-4xl text-navy-900"
      >
        What you'll get every week.
      </h2>
    </ScrollReveal>

    <ul class="mt-8 space-y-5" role="list">
      {
        benefits.map((benefit, i) => (
          <ScrollReveal delay={i * 100} tag="li">
            <div class="flex items-start gap-4">
              <svg
                class="shrink-0 mt-1 h-5 w-5 text-gold-500"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M16.704 5.29a1 1 0 0 1 .006 1.414l-7.07 7.115a1 1 0 0 1-1.42.007L3.29 8.91a1 1 0 1 1 1.42-1.408l4.22 4.257 6.36-6.4a1 1 0 0 1 1.414-.07z"
                  clip-rule="evenodd"
                />
              </svg>
              <span class="text-lg text-navy-900 leading-relaxed">
                {benefit}
              </span>
            </div>
          </ScrollReveal>
        ))
      }
    </ul>
  </section>

  <!-- ============================================================
       Social proof (hidden until testimonials exist)
       ============================================================ -->
  {
    TESTIMONIALS.length > 0 && (
      <section
        class="bg-navy-100 border-y border-navy-200"
        aria-labelledby="social-proof-heading"
      >
        <div class="max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
          <ScrollReveal>
            <h2
              id="social-proof-heading"
              class="font-serif text-3xl md:text-4xl text-navy-900 text-center"
            >
              What readers are saying.
            </h2>
          </ScrollReveal>

          <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {TESTIMONIALS.map((t, i) => (
              <ScrollReveal delay={i * 80}>
                <figure class="card rounded-lg p-6">
                  <svg
                    class="h-7 w-7 text-gold-400"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M7.17 6A5 5 0 0 0 3 11v7h7v-7H5.5A3.5 3.5 0 0 1 9 7.5V6H7.17zM17.17 6A5 5 0 0 0 13 11v7h7v-7h-4.5A3.5 3.5 0 0 1 19 7.5V6h-1.83z" />
                  </svg>
                  <blockquote class="mt-3 font-serif text-xl text-navy-900 leading-snug italic">
                    "{t.quote}"
                  </blockquote>
                  <figcaption class="mt-4 text-sm">
                    <span class="font-semibold text-navy-900">{t.name}</span>
                    {(t.role || t.company) && (
                      <span class="block text-navy-700">
                        {t.role}
                        {t.role && t.company && ' · '}
                        {t.company}
                      </span>
                    )}
                  </figcaption>
                </figure>
              </ScrollReveal>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- ============================================================
       Recent issues (hidden until data exists)
       ============================================================ -->
  {
    recentIssues.length > 0 && (
      <section
        class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-20"
        aria-labelledby="recent-issues-heading"
      >
        <ScrollReveal>
          <h2
            id="recent-issues-heading"
            class="font-serif text-3xl md:text-4xl text-navy-900"
          >
            Recent issues.
          </h2>
        </ScrollReveal>

        <ol class="mt-8 divide-y divide-navy-100 card rounded-lg overflow-hidden">
          {recentIssues.map((issue) => (
            <li class="p-5 flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-2">
              <div class="min-w-0">
                {issue.url ? (
                  <a
                    href={issue.url}
                    class="font-serif text-xl text-navy-900 hover:text-gold-700 transition-colors"
                  >
                    {issue.title}
                  </a>
                ) : (
                  <span class="font-serif text-xl text-navy-900">
                    {issue.title}
                  </span>
                )}
                {issue.summary && (
                  <p class="mt-1 text-sm text-navy-700 leading-relaxed">
                    {issue.summary}
                  </p>
                )}
              </div>
              <time
                datetime={issue.date.toISOString()}
                class="eyebrow shrink-0 text-navy-500"
              >
                {issue.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </li>
          ))}
        </ol>
      </section>
    )
  }

  <!-- ============================================================
       Closing CTA
       ============================================================ -->
  <section class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
    <ScrollReveal>
      <div
        class="card-featured card rounded-lg border-t-2 border-t-gold-500 p-8 md:p-12 text-center"
      >
        <h2 class="font-serif text-3xl md:text-4xl text-navy-900">
          Start getting The FSO Brief this week.
        </h2>
        <p class="mt-3 text-navy-800/80">
          Free. One email per week. Unsubscribe any time.
        </p>
        <a
          href="#newsletter-email"
          class="mt-8 inline-flex items-center justify-center rounded-md bg-navy-900 px-7 py-3 font-semibold text-white hover:bg-navy-950 transition-colors"
        >
          Subscribe free
        </a>
      </div>
    </ScrollReveal>
  </section>
</BaseLayout>
