---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search articles, guides, and templates.">
  <Fragment slot="head">
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script src="/pagefind/pagefind-ui.js" defer is:inline></script>
  </Fragment>

  <section class="max-w-3xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-20">
    <p class="eyebrow text-gold-700">Site search</p>
    <h1
      class="mt-3 font-serif text-5xl md:text-6xl text-navy-900 leading-[1.05] tracking-[-0.025em]"
    >
      Search.
    </h1>
    <p class="mt-5 text-lg text-navy-800/80 leading-relaxed">
      Find articles, guides, and templates across the site.
    </p>

    <div id="search" class="mt-10"></div>

    <script is:inline>
      // Rebind on astro:page-load so View Transitions don't leave search stale.
      function initPagefind() {
        const container = document.getElementById('search');
        if (!container || container.dataset.enhanced) return;
        const run = () => {
          if (typeof window.PagefindUI !== 'undefined') {
            container.dataset.enhanced = 'true';
            new window.PagefindUI({
              element: '#search',
              showSubResults: true,
              showImages: false,
              resetStyles: false,
              translations: { placeholder: 'Search…' },
            });
          } else {
            setTimeout(run, 100);
          }
        };
        run();
      }
      document.addEventListener('astro:page-load', initPagefind);
    </script>
  </section>
</BaseLayout>
