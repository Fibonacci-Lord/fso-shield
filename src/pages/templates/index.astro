---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import JsonLd from '../../components/JsonLd.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import EmailSignup from '../../components/EmailSignup.astro';

const products = (await getCollection('products')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return a.data.featured ? -1 : 1;
  }
  return a.data.title.localeCompare(b.data.title);
});

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Templates', url: '/templates', current: true },
];
---

<BaseLayout
  title="Templates & Digital Products"
  description="Ready-to-use templates, checklists, and digital products for Facility Security Officers — NISPOM compliance, FCL paperwork, insider threat programs, and more."
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <section
    class="hero-ink relative overflow-hidden border-b-4 border-gold-500"
  >
    <div class="hero-grid absolute inset-0 opacity-40" aria-hidden="true"></div>
    <div
      class="relative max-w-4xl mx-auto px-6 sm:px-8 lg:px-12 py-16 md:py-24"
    >
      <Breadcrumbs items={breadcrumbItems} tone="light" />
      <ScrollReveal>
        <p class="eyebrow mt-5 text-gold-300">The Store</p>
      </ScrollReveal>
      <ScrollReveal delay={80}>
        <h1
          class="mt-3 font-serif text-white leading-[1.05] tracking-[-0.025em]
                 text-[2.75rem] sm:text-[3.25rem] md:text-[4rem] max-w-[18ch]"
        >
          Templates & digital products.
        </h1>
      </ScrollReveal>
      <ScrollReveal delay={160}>
        <p
          class="mt-5 text-lg md:text-xl text-navy-100 max-w-2xl leading-relaxed"
        >
          Ready-to-use documents, checklists, and policies built for working
          FSOs. Instant delivery, lifetime updates.
        </p>
      </ScrollReveal>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-16">
    {
      products.length === 0 ? (
        <p class="text-navy-700">
          Products will appear here as they're published.
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {products.map((product, i) => (
            <ScrollReveal delay={i * 80}>
              <ProductCard product={product} />
            </ScrollReveal>
          ))}
        </div>
      )
    }
  </section>

  <EmailSignup variant="band" />
</BaseLayout>
