---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import JsonLd from '../../components/JsonLd.astro';

const products = (await getCollection('products')).sort((a, b) => {
  if (a.data.featured !== b.data.featured) {
    return a.data.featured ? -1 : 1;
  }
  return a.data.title.localeCompare(b.data.title);
});

const breadcrumbItems = [
  { name: 'Home', url: '/' },
  { name: 'Templates', url: '/templates', current: true },
];
---

<BaseLayout
  title="Templates & Digital Products"
  description="Ready-to-use templates, checklists, and digital products for Facility Security Officers — NISPOM compliance, FCL paperwork, insider threat programs, and more."
>
  <JsonLd type="BreadcrumbList" data={{ items: breadcrumbItems }} />

  <section class="bg-navy-700 text-white border-b-4 border-gold-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <Breadcrumbs items={breadcrumbItems} />
      <h1
        class="mt-3 font-serif text-4xl md:text-5xl text-white leading-tight"
      >
        Templates & digital products
      </h1>
      <p class="mt-4 text-lg text-navy-100 max-w-2xl">
        Ready-to-use documents, checklists, and policies built for working
        FSOs. Instant delivery.
      </p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    {
      products.length === 0 ? (
        <p class="text-navy-600">
          Products will appear here as they're published.
        </p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {products.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
