---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ProductCard from '../components/ProductCard.astro';
import EmailSignup from '../components/EmailSignup.astro';
import { CATEGORY_META, categorySlugs } from '../content.config';
import { SITE } from '../consts';

const posts = (await getCollection('blog', (p) => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const featuredProducts = (await getCollection('products'))
  .filter((p) => p.data.featured)
  .slice(0, 6);
---

<BaseLayout title={SITE.name} description={SITE.description}>
  <section class="bg-navy-700 text-white border-b-4 border-gold-500">
    <div
      class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-20 text-center"
    >
      <p
        class="inline-block text-xs font-semibold uppercase tracking-widest text-gold-300"
      >
        For Facility Security Officers
      </p>
      <h1 class="mt-3 font-serif text-4xl md:text-5xl lg:text-6xl text-white leading-tight">
        Practical industrial security training, in plain English.
      </h1>
      <p class="mt-5 text-lg md:text-xl text-navy-100 max-w-2xl mx-auto">
        {SITE.description}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/fso-training"
          class="inline-flex items-center justify-center rounded bg-gold-500 px-6 py-3 font-semibold text-navy-900 hover:bg-gold-400"
          >Start with FSO Training</a
        >
        <a
          href="/templates"
          class="inline-flex items-center justify-center rounded border border-gold-400 px-6 py-3 font-semibold text-gold-300 hover:bg-navy-800"
          >Browse Templates</a
        >
      </div>
    </div>
  </section>

  <section
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12"
    aria-labelledby="topics-heading"
  >
    <h2 id="topics-heading" class="font-serif text-2xl md:text-3xl text-navy-800">
      Core topics
    </h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        categorySlugs.map((slug) => {
          const cat = CATEGORY_META[slug];
          return (
            <a
              href={cat.path}
              class="block rounded-lg border border-navy-100 bg-white p-6 hover:border-gold-400 hover:shadow-md transition-all"
            >
              <h3 class="font-serif text-xl text-navy-800">{cat.label}</h3>
              <p class="mt-2 text-navy-900/75 text-[0.95rem]">
                {cat.description}
              </p>
              <span class="mt-3 inline-block text-sm font-semibold text-navy-700">
                Explore →
              </span>
            </a>
          );
        })
      }
    </div>
  </section>

  <section
    class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12"
    aria-labelledby="latest-heading"
  >
    <div class="flex items-end justify-between gap-4 flex-wrap">
      <h2 id="latest-heading" class="font-serif text-2xl md:text-3xl text-navy-800">
        Latest articles
      </h2>
      <a
        href="/rss.xml"
        class="text-sm font-semibold text-navy-700 hover:text-gold-700"
        >RSS feed</a
      >
    </div>
    {
      posts.length === 0 ? (
        <p class="mt-4 text-navy-600">
          New articles will appear here as they're published.
        </p>
      ) : (
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      )
    }
  </section>

  {
    featuredProducts.length > 0 && (
      <section
        class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12"
        aria-labelledby="featured-products"
      >
        <div class="flex items-end justify-between gap-4 flex-wrap">
          <h2
            id="featured-products"
            class="font-serif text-2xl md:text-3xl text-navy-800"
          >
            Featured templates
          </h2>
          <a
            href="/templates"
            class="text-sm font-semibold text-navy-700 hover:text-gold-700"
          >
            View all →
          </a>
        </div>
        <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {featuredProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </section>
    )
  }

  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <EmailSignup />
  </section>
</BaseLayout>
