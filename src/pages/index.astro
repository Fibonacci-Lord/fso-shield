---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import ProductCard from '../components/ProductCard.astro';
import EmailSignup from '../components/EmailSignup.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
import { CATEGORY_META, categorySlugs } from '../content.config';
import { SITE } from '../consts';

const posts = (await getCollection('blog', (p) => !p.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);

const allProducts = await getCollection('products');
const bundle = allProducts.find((p) => p.id === 'complete-dcsa-assessment-kit');
const featuredProducts = allProducts
  .filter((p) => p.data.featured && p.id !== 'complete-dcsa-assessment-kit')
  .slice(0, 4);
---

<BaseLayout title={SITE.name} description={SITE.description}>
  <!-- ============================================================
       Hero — deep ink with faint grid texture and editorial serif
       ============================================================ -->
  <section
    class="hero-ink relative overflow-hidden border-b-4 border-gold-500"
  >
    <div class="hero-grid absolute inset-0 opacity-40" aria-hidden="true"></div>

    <div
      class="relative max-w-5xl mx-auto px-6 sm:px-8 lg:px-12 py-20 md:py-28"
    >
      <ScrollReveal>
        <p class="eyebrow text-gold-300">For Facility Security Officers</p>
      </ScrollReveal>

      <ScrollReveal delay={100}>
        <h1
          class="mt-5 font-serif text-white leading-[1.02] tracking-[-0.025em]
                 text-[3rem] sm:text-[3.75rem] md:text-[4.5rem] lg:text-[5rem]
                 max-w-[18ch]"
        >
          Practical industrial security training, in plain English.
        </h1>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <p class="mt-6 text-lg md:text-xl text-navy-100 max-w-2xl leading-relaxed">
          {SITE.description}
        </p>
      </ScrollReveal>

      <ScrollReveal delay={300}>
        <div class="mt-10 flex flex-col sm:flex-row gap-3">
          <a
            href="/assessment-kit"
            class="inline-flex items-center justify-center rounded-md bg-gold-500
                   px-7 py-3.5 font-semibold text-navy-950 hover:bg-gold-400
                   focus:outline-none focus:ring-2 focus:ring-offset-2
                   focus:ring-gold-400 focus:ring-offset-navy-950
                   transition-colors"
          >
            Get the Assessment Kit →
          </a>
          <a
            href="/fso-training"
            class="inline-flex items-center justify-center rounded-md
                   border border-gold-400/70 bg-transparent px-7 py-3.5
                   font-semibold text-gold-300 hover:bg-navy-900
                   hover:border-gold-400 transition-colors"
          >
            Start with FSO Training
          </a>
        </div>
        <p class="mt-5 text-sm text-navy-200/80">
          or <a href="/templates" class="underline underline-offset-2 hover:text-gold-300 transition-colors">browse individual templates</a>
        </p>
      </ScrollReveal>

      <ScrollReveal delay={450}>
        <p class="eyebrow mt-12 text-navy-300/80">
          Built for FSOs managing cleared programs under 32&nbsp;CFR Part 117
        </p>
      </ScrollReveal>
    </div>
  </section>

  <!-- ============================================================
       Lead magnet banner — editorial nudge below the hero
       ============================================================ -->
  <section
    class="bg-navy-900 border-b border-gold-500/30"
    aria-label="Free resource"
  >
    <div
      class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-3.5 flex flex-col sm:flex-row sm:items-center sm:justify-center gap-2 sm:gap-4 text-sm text-navy-100"
    >
      <span class="inline-flex items-center gap-2">
        <span class="eyebrow text-gold-300">Free</span>
        <span>Start with our 15-item NISPOM Quick-Check.</span>
      </span>
      <a
        href="/free-checklist"
        class="font-semibold text-gold-300 hover:text-gold-200 underline underline-offset-4 decoration-gold-500/60 transition-colors"
      >
        Download the checklist →
      </a>
    </div>
  </section>

  <!-- ============================================================
       Core topics — five pillar cards
       ============================================================ -->
  <section
    class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-20"
    aria-labelledby="topics-heading"
  >
    <ScrollReveal>
      <h2
        id="topics-heading"
        class="font-serif text-3xl md:text-4xl text-navy-900 max-w-[20ch]"
      >
        Core topics for working FSOs.
      </h2>
    </ScrollReveal>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        categorySlugs.map((slug, i) => {
          const cat = CATEGORY_META[slug];
          return (
            <ScrollReveal delay={i * 80}>
              <a
                href={cat.path}
                class="card group relative flex h-full flex-col rounded-lg
                       border-t-2 border-transparent p-6
                       hover:border-t-gold-500"
              >
                <h3 class="font-serif text-xl text-navy-900">{cat.label}</h3>
                <p class="mt-2 text-navy-800/80 text-[0.95rem] leading-relaxed flex-1">
                  {cat.description}
                </p>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-navy-800 group-hover:text-gold-700 transition-colors">
                  Explore
                  <span
                    class="transition-transform group-hover:translate-x-0.5"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </span>
              </a>
            </ScrollReveal>
          );
        })
      }
    </div>
  </section>

  <!-- ============================================================
       Latest articles
       ============================================================ -->
  <section
    class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-20"
    aria-labelledby="latest-heading"
  >
    <ScrollReveal>
      <div class="flex items-end justify-between gap-4 flex-wrap">
        <h2
          id="latest-heading"
          class="font-serif text-3xl md:text-4xl text-navy-900"
        >
          Latest articles.
        </h2>
        <a
          href="/rss.xml"
          class="text-sm font-semibold text-navy-700 hover:text-gold-700 transition-colors"
        >
          RSS feed →
        </a>
      </div>
    </ScrollReveal>

    {
      posts.length === 0 ? (
        <p class="mt-6 text-navy-700">
          New articles will appear here as they're published.
        </p>
      ) : (
        <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post, i) => (
            <ScrollReveal delay={i * 80}>
              <ArticleCard post={post} />
            </ScrollReveal>
          ))}
        </div>
      )
    }
  </section>

  <!-- ============================================================
       Featured templates — bundle is the hero
       ============================================================ -->
  {
    (bundle || featuredProducts.length > 0) && (
      <section
        class="max-w-6xl mx-auto px-6 sm:px-8 lg:px-12 py-20"
        aria-labelledby="featured-products"
      >
        <ScrollReveal>
          <div class="flex items-end justify-between gap-4 flex-wrap">
            <h2
              id="featured-products"
              class="font-serif text-3xl md:text-4xl text-navy-900"
            >
              Featured templates.
            </h2>
            <a
              href="/templates"
              class="text-sm font-semibold text-navy-700 hover:text-gold-700 transition-colors"
            >
              View all →
            </a>
          </div>
        </ScrollReveal>

        {bundle && (
          <ScrollReveal delay={60}>
            <a
              href="/assessment-kit"
              class="group mt-10 block rounded-lg border-2 border-gold-500 bg-navy-900 text-white p-7 md:p-10 hover:border-gold-400 hover:bg-navy-950 transition-colors relative overflow-hidden"
            >
              <div class="hero-grid absolute inset-0 opacity-20" aria-hidden="true" />
              <div class="relative grid gap-6 md:grid-cols-[1.4fr_1fr] md:items-center">
                <div>
                  <div class="flex items-center gap-3 flex-wrap">
                    <span class="inline-block rounded-full bg-gold-500 px-3 py-1 text-[11px] font-bold uppercase tracking-wider text-navy-950">
                      Best value
                    </span>
                    <span class="eyebrow text-gold-300">The complete kit</span>
                  </div>
                  <h3 class="mt-3 font-serif text-3xl md:text-4xl leading-tight text-white">
                    The Complete DCSA Assessment Kit.
                  </h3>
                  <p class="mt-3 text-navy-100 leading-relaxed max-w-xl">
                    All four core FSO compliance templates — checklist, ITP
                    documents, SPP, and briefing decks. One download. Zero
                    surprises on assessment day.
                  </p>
                </div>
                <div class="md:text-right">
                  <p class="font-serif text-5xl md:text-6xl text-white">$297</p>
                  <p class="mt-1 text-sm text-navy-300">All 4 products included</p>
                  <span class="mt-5 inline-flex items-center gap-1 rounded-md bg-gold-500 px-6 py-3 font-semibold text-navy-950 group-hover:bg-gold-400 transition-colors">
                    See the kit →
                  </span>
                </div>
              </div>
            </a>
          </ScrollReveal>
        )}

        {featuredProducts.length > 0 && (
          <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {featuredProducts.map((product, i) => (
              <ScrollReveal delay={i * 80}>
                <ProductCard product={product} />
              </ScrollReveal>
            ))}
          </div>
        )}
      </section>
    )
  }

  <!-- ============================================================
       Newsletter — full-bleed dark band
       ============================================================ -->
  <EmailSignup variant="band" />
</BaseLayout>
